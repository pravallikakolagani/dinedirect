{
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "customer.js",
      "use": "@vercel/static"
    },
    {
      "src": "owner.js",
      "use": "@vercel/static"
    },
    {
      "src": "kds.js",
      "use": "@vercel/static"
    },
    {
      "src": "state.js",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "customer.css",
      "use": "@vercel/static"
    },
    {
      "src": "owner.css",
      "use": "@vercel/static"
    },
    {
      "src": "kds.css",
      "use": "@vercel/static"
    },
    {
      "src": "images/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    }
  ]
}
